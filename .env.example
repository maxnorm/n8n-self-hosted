# ---------------------------------------------------------
# N8N settings
# ---------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Enable task runners for Code nodes and advanced features
N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=CHANGE_ME_GENERATE_A_LONG_RANDOM_KEY

# Enforce strict file permissions on startup (credential files)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# Enable public API for backup automation (auto-seeded on first boot)
N8N_PUBLIC_API_ENABLED=true

# Execution data retention
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=5000
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all

# Concurrency control
N8N_CONCURRENCY_PRODUCTION_LIMIT=5

N8N_WORKFLOW_AUTODEACTIVATION_ENABLED=true
N8N_WORKFLOW_AUTODEACTIVATION_MAX_LAST_EXECUTIONS=10

# ---------------------------------------------------------
# Reverse proxy / Cloudflare Tunnel
# ---------------------------------------------------------
# When n8n sits behind a tunnel or reverse proxy, set to 1 (or higher if chained).
N8N_PROXY_HOPS=1

# Use this for local testing (trailing slash recommended)
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/

# Change this before production
GENERIC_TIMEZONE=America/Toronto
TZ=America/Toronto

# Important: keep this forever.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_KEY

# ---------------------------------------------------------
# N8N user management
# ---------------------------------------------------------
N8N_PERSONALIZATION_ENABLED=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# ---------------------------------------------------------
# N8N logging
# ---------------------------------------------------------
# Levels: error, warn, info, debug. Use warn for production, info for initial setup.
N8N_LOG_LEVEL=warn
N8N_LOG_OUTPUT=console

# ---------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=n8n

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_SCHEMA=n8n

# ---------------------------------------------------------
# Instance owner (pre-provisioned on every startup)
# Available since n8n v2.17.0
# ---------------------------------------------------------
N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
N8N_INSTANCE_OWNER_EMAIL=admin@yourcompany.com
N8N_INSTANCE_OWNER_FIRST_NAME=Admin
N8N_INSTANCE_OWNER_LAST_NAME=User
# Generate bcrypt hash with:
#   docker run --rm httpd:alpine htpasswd -bnBC 10 "" 'YOUR_PASSWORD' | tr -d ':\n' | sed 's/$2y/$2a/'
N8N_INSTANCE_OWNER_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
# Plaintext password — used by init script to create API key on first boot.
# This is only used during first boot to seed the API key.
N8N_INSTANCE_OWNER_PASSWORD=CHANGE_ME_CHOOSE_A_STRONG_PASSWORD